{% comment %}
  Mobile-only "Clinically Proven" dropdown widget with dummy values
  Shows 6 images with text in a 3x2 grid when clicked
{% endcomment %}

<div class="good-for-widget mobile-only">
  <div class="good-for-header">
    <h3>Clinically Proven, Naturally Effective</h3>
    <span class="toggle-icon">+</span>
  </div>
  <div class="good-for-content">
    <div class="good-for-grid">
      <!-- Item 1 -->
      <div class="good-for-item">
        <img src="//powernoshnutrition.com/cdn/shop/files/hour-glass.png?v=1731664631&width=710" alt="Cognitive Function">
        <p>Cognitive Function</p>
      </div>
      
      <!-- Item 2 -->
      <div class="good-for-item">
        <img src="//powernoshnutrition.com/cdn/shop/files/weight.png?v=1731664668&width=710" alt="Bipolar Relief">
        <p>Bipolar Relief</p>
      </div>
      
      <!-- Item 3 -->
      <div class="good-for-item">
        <img src="//powernoshnutrition.com/cdn/shop/files/puzzle.png?v=1731664708&width=710" alt="Treats ADHD">
        <p>ADHD Control</p>
      </div>
      
      <!-- Item 4 -->
      <div class="good-for-item">
        <img src="//powernoshnutrition.com/cdn/shop/files/Brain.png?v=1731665127&width=710" alt="Schizophrenia Aid
">
        <p>Schizophrenia Aid
</p>
      </div>
      
      <!-- Item 5 -->
      <div class="good-for-item">
        <img src="//powernoshnutrition.com/cdn/shop/files/Emoji.png?v=1731664729&width=710" alt="Alzheimer’s Support
">
        <p>Alzheimer’s Support
</p>
      </div>
      
      <!-- Item 6 -->
<!--      <div class="good-for-item">
        <img src="//powernoshnutrition.com/cdn/shop/files/Emoji.png?v=1731664729&width=710" alt="Energy Boost">
        <p>Energy Boost</p>
      </div>
    </div>
  </div>
</div> -->

<style>
  .good-for-widget {
    border-bottom: 1px solid #e1e1e1;
    margin-bottom: 20px;
  }
  
  .good-for-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
    cursor: pointer;
  }
  
  .good-for-header h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }
  
  .toggle-icon {
    font-size: 20px;
  }
  
  .good-for-content {
    display: none;
    padding-bottom: 20px;
  }
  
  .good-for-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap:25px;
  }
  
  .good-for-item {
    text-align: center;
  }
  
  .good-for-item img {
    width: 100%;
    max-width: 55px;
    height: auto;
    margin: 0 auto;
    display: block;
  }
  
  .good-for-item p {
    margin: 8px 0 0;
    font-size: 10px;
  }
  
  .mobile-only {
    display: none;
  }
  
  @media only screen and (max-width: 749px) {
    .mobile-only {
      display: block;
    }
    
    .good-for-widget.active .good-for-content {
      display: block;
    }
    
    .good-for-widget.active .toggle-icon {
      transform: rotate(45deg);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const goodForWidget = document.querySelector('.good-for-widget');
    if (goodForWidget) {
      goodForWidget.querySelector('.good-for-header').addEventListener('click', function() {
        goodForWidget.classList.toggle('active');
      });
    }
  });
</script>
